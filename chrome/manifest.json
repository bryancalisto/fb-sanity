{
  "name": "FB Sanity",
  "description": "Facebook extension to hide reactions section and stay away from its toxicity",
  "version": "0.1",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://facebook.com/*",
        "https://*.facebook.com/*"
      ],
      "js": ["main.js"],
      "run_at": "document_idle"
    }
  ]
}
